{
  "name": "yakudoc",
  "version": "0.1.0",
  "description": "Show JSDoc comments translated into your language in the editor — CLI and core library (init / extract / status / translate)",
  "license": "MIT",
  "engines": {
    "node": ">=18.17"
  },
  "keywords": [
    "jsdoc",
    "tsdoc",
    "translation",
    "japanese",
    "i18n",
    "typescript",
    "documentation",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daiki-moritake/yakudoc.git",
    "directory": "packages/yakudoc"
  },
  "homepage": "https://github.com/daiki-moritake/yakudoc#readme",
  "bugs": {
    "url": "https://github.com/daiki-moritake/yakudoc/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "yakudoc": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "typescript": "^5.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0"
  }
}
