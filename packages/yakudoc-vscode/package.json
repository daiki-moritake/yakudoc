{
  "name": "yakudoc-vscode",
  "displayName": "yakudoc",
  "description": "%yakudoc.description%",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "publisher": "yakudoc",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/daiki-moritake/yakudoc.git",
    "directory": "packages/yakudoc-vscode"
  },
  "homepage": "https://github.com/daiki-moritake/yakudoc#readme",
  "bugs": {
    "url": "https://github.com/daiki-moritake/yakudoc/issues"
  },
  "keywords": [
    "jsdoc",
    "translation",
    "japanese",
    "日本語",
    "翻訳",
    "typescript",
    "hover",
    "documentation"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "galleryBanner": {
    "color": "#1e2a45",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact"
  ],
  "contributes": {
    "commands": [
      {
        "command": "yakudoc.init",
        "category": "yakudoc",
        "title": "%yakudoc.command.init.title%"
      },
      {
        "command": "yakudoc.toggle",
        "category": "yakudoc",
        "title": "%yakudoc.command.toggle.title%"
      },
      {
        "command": "yakudoc.registerPlugin",
        "category": "yakudoc",
        "title": "%yakudoc.command.registerPlugin.title%"
      },
      {
        "command": "yakudoc.extract",
        "category": "yakudoc",
        "title": "%yakudoc.command.extract.title%"
      },
      {
        "command": "yakudoc.showStatus",
        "category": "yakudoc",
        "title": "%yakudoc.command.showStatus.title%"
      }
    ],
    "configuration": {
      "title": "yakudoc",
      "properties": {
        "yakudoc.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%yakudoc.config.enabled.description%"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs --target=node18",
    "test": "node --experimental-test-module-mocks --import tsx --test tests/*.test.ts",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "jsonc-parser": "^3.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vscode": "file:test/vscode-stub"
  }
}
