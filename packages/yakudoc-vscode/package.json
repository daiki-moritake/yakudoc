{
  "name": "yakudoc-vscode",
  "displayName": "yakudoc",
  "description": "JSDoc のホバー・補完・シグネチャヘルプを日本語訳で表示する yakudoc-ts-plugin の管理 UI",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "publisher": "yakudoc",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact"
  ],
  "contributes": {
    "commands": [
      {
        "command": "yakudoc.toggle",
        "title": "yakudoc: 翻訳表示を切り替え (JP/EN)"
      },
      {
        "command": "yakudoc.registerPlugin",
        "title": "yakudoc: tsconfig.json にプラグインを登録"
      }
    ],
    "configuration": {
      "title": "yakudoc",
      "properties": {
        "yakudoc.enabled": {
          "type": "boolean",
          "default": true,
          "description": "JSDoc の表示(ホバー・補完・シグネチャヘルプ)を日本語訳に差し替える"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.85.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
